---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SEO from "../components/SEO.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: URL;
	navClass?: string;
	isNavDark?: boolean;
}

const {
	title = "Sweet Delights | Artisanal Pastry Shop",
	description = "Discover the perfect blend of traditional recipes and modern techniques at Sweet Delights, your local artisanal bakery.",
	image = "https://images.unsplash.com/photo-1555507036-ab1f4038808a?q=80&w=1200",
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
	navClass = "",
	isNavDark = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<SEO title={title} description={description} image={image} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Sitemap -->
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
			rel="stylesheet"
		/>

		<ClientRouter />
	</head>
	<body>
		<Navigation class={navClass} isDark={isNavDark} />
		<slot />
		<ScrollToTop />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
