---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
---

<Layout
	title="Sweet Delights | Artisanal Pastry Shop"
	description="Experience the finest artisanal pastries, from flaky croissants to custom wedding cakes. Freshly baked every day in Bake City."
	navClass="absolute top-0 left-0"
	isNavDark={true}
>
	<main>
		<!-- Hero Section -->
		<section
			class="relative h-[80vh] flex items-center justify-center overflow-hidden"
		>
			<div
				class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1555507036-ab1f4038808a?q=80&w=2000')] bg-cover bg-center"
			>
				<div class="absolute inset-0 bg-black/40"></div>
			</div>

			<div class="relative z-10 text-center px-4 max-w-4xl">
				<h1 class="text-5xl md:text-7xl text-white mb-6 leading-tight">
					Artisanal Pastries <br />
					<span class="italic font-light text-brand-accent"
						>Crafted with Love</span
					>
				</h1>
				<p
					class="text-xl text-stone-100 mb-8 font-light max-w-2xl mx-auto"
				>
					Discover the perfect blend of traditional recipes and modern
					techniques in every bite.
				</p>
				<div class="flex gap-4 justify-center">
					<a
						href="/menu"
						class="px-8 py-3 bg-brand-secondary text-white rounded-full hover:bg-brand-primary transition-colors text-lg font-medium"
					>
						View Menu
					</a>
					<a
						href="#contact"
						class="px-8 py-3 bg-white/10 backdrop-blur-md border border-white/20 text-white rounded-full hover:bg-white/20 transition-colors text-lg font-medium"
					>
						Contact Us
					</a>
				</div>
			</div>
		</section>

		<!-- Menu Section -->
		<section id="menu" class="py-24 px-4 bg-stone-50">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-4xl md:text-5xl mb-4 text-brand-primary">
						Our Specialties
					</h2>
					<div class="w-24 h-1 bg-brand-secondary mx-auto mb-6"></div>
					<p class="text-stone-600 max-w-xl mx-auto">
						From flaky croissants to exquisite custom cakes, explore
						our seasonal selections.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					<!-- Category 1 -->
					<div
						class="group relative overflow-hidden rounded-2xl aspect-square shadow-xl transition-all hover:-translate-y-2"
					>
						<Image
							src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=800"
							alt="Cakes"
							width={800}
							height={800}
							class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8"
						>
							<h3 class="text-2xl text-white mb-2">
								Exquisite Cakes
							</h3>
							<p
								class="text-stone-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity"
							>
								Custom creations for every occasion.
							</p>
						</div>
					</div>
					<!-- Category 2 -->
					<div
						class="group relative overflow-hidden rounded-2xl aspect-square shadow-xl transition-all hover:-translate-y-2"
					>
						<Image
							src="https://images.unsplash.com/photo-1509365465985-25d11c17e812?q=80&w=800"
							alt="Pastries"
							width={800}
							height={800}
							class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8"
						>
							<h3 class="text-2xl text-white mb-2">
								Daily Pastries
							</h3>
							<p
								class="text-stone-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity"
							>
								Freshly baked every morning.
							</p>
						</div>
					</div>
					<!-- Category 3 -->
					<div
						class="group relative overflow-hidden rounded-2xl aspect-square shadow-xl transition-all hover:-translate-y-2"
					>
						<Image
							src="https://images.unsplash.com/photo-1495147466023-ac5c588e2e94?q=80&w=800"
							alt="Cookies"
							width={800}
							height={800}
							class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-8"
						>
							<h3 class="text-2xl text-white mb-2">
								Artisanal Cookies
							</h3>
							<p
								class="text-stone-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity"
							>
								The perfect companion for your coffee.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- About Teaser Section -->
		<section class="py-24 px-4 bg-white overflow-hidden">
			<div
				class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center"
			>
				<div class="relative order-2 md:order-1">
					<Image
						src="https://images.unsplash.com/photo-1549931319-a545dcf3bc73?q=80&w=800"
						alt="Our Bakery"
						width={800}
						height={600}
						class="rounded-3xl shadow-2xl transition-transform hover:scale-105 duration-700"
					/>
					<div
						class="absolute -bottom-6 -right-6 bg-brand-accent p-8 rounded-2xl hidden md:block"
					>
						<p
							class="font-serif text-3xl text-brand-primary italic"
						>
							Est. 2010
						</p>
					</div>
				</div>
				<div class="space-y-8 order-1 md:order-2">
					<h2 class="text-4xl md:text-5xl text-brand-primary italic">
						A Heart for Baking
					</h2>
					<div class="w-20 h-1 bg-brand-secondary"></div>
					<p
						class="text-stone-600 text-lg font-light leading-relaxed"
					>
						What started as a small family recipe has grown into a
						destination for pastry lovers. We believe in the slow
						way of doing things—from sourdough that takes days to
						rise to hand-laminated pastry layers.
					</p>
					<a
						href="/about"
						class="inline-flex items-center gap-2 text-brand-secondary font-bold uppercase tracking-widest text-sm group hover:text-brand-primary transition-colors"
					>
						Read Our Full Story
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="w-4 h-4 transition-transform group-hover:translate-x-2"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
						</svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contact" class="py-24 px-4 bg-white">
			<div
				class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center"
			>
				<div>
					<h2 class="text-4xl mb-6 text-brand-primary">
						Visit Our Shop
					</h2>
					<p class="text-stone-600 mb-8 leading-relaxed">
						Stop by to experience the aroma of fresh baking and pick
						up your favorite treats. For custom orders, please fill
						out the form or give us a call.
					</p>

					<div class="space-y-4">
						<div class="flex items-center gap-4 text-stone-700">
							<div
								class="w-10 h-10 rounded-full bg-brand-accent flex items-center justify-center text-brand-primary"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="w-5 h-5"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
									></path>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
									></path>
								</svg>
							</div>
							<span>123 Patisserie Lane, Bake City</span>
						</div>
						<div class="flex items-center gap-4 text-stone-700">
							<div
								class="w-10 h-10 rounded-full bg-brand-accent flex items-center justify-center text-brand-primary"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="w-5 h-5"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
									></path>
								</svg>
							</div>
							<span>+1 (555) 123-4567</span>
						</div>
						<div class="flex items-center gap-4 text-stone-700">
							<div
								class="w-10 h-10 rounded-full bg-brand-accent flex items-center justify-center text-brand-primary"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="w-5 h-5"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
									></path>
								</svg>
							</div>
							<span>Tue - Sun: 8am - 6pm</span>
						</div>
					</div>
				</div>

				<form
					id="contact-form"
					class="space-y-6 p-8 bg-stone-50 rounded-3xl border border-stone-100 shadow-sm relative overflow-hidden"
				>
					<div
						id="form-success"
						class="absolute inset-0 bg-white/95 backdrop-blur-sm z-50 flex flex-col items-center justify-center text-center p-8 translate-y-full transition-transform duration-500"
					>
						<div
							class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="w-8 h-8"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M5 13l4 4L19 7"></path>
							</svg>
						</div>
						<h3 class="text-2xl text-brand-primary mb-2 italic">
							Message Received!
						</h3>
						<p class="text-stone-500 text-sm">
							We'll get back to you shortly over some fresh
							cookies.
						</p>
						<button
							type="button"
							id="reset-form"
							class="mt-8 text-brand-secondary font-bold uppercase tracking-widest text-xs"
							>Send another one</button
						>
					</div>

					<div class="grid md:grid-cols-2 gap-6">
						<div class="space-y-2">
							<label class="text-sm font-medium text-stone-700"
								>Name</label
							>
							<input
								type="text"
								required
								placeholder="Your Name"
								class="w-full px-4 py-3 rounded-xl bg-white border border-stone-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary/20 focus:border-brand-secondary transition-all"
							/>
						</div>
						<div class="space-y-2">
							<label class="text-sm font-medium text-stone-700"
								>Email</label
							>
							<input
								type="email"
								required
								placeholder="Email Address"
								class="w-full px-4 py-3 rounded-xl bg-white border border-stone-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary/20 focus:border-brand-secondary transition-all"
							/>
						</div>
					</div>
					<div class="space-y-2">
						<label class="text-sm font-medium text-stone-700"
							>Message</label
						>
						<textarea
							rows="4"
							required
							placeholder="How can we help you?"
							class="w-full px-4 py-3 rounded-xl bg-white border border-stone-200 focus:outline-none focus:ring-2 focus:ring-brand-secondary/20 focus:border-brand-secondary transition-all resize-none"
						></textarea>
					</div>
					<button
						type="submit"
						class="w-full py-4 bg-brand-primary text-white rounded-xl hover:bg-stone-800 transition-colors font-semibold shadow-lg shadow-brand-primary/10"
					>
						Send Message
					</button>
				</form>

				<script>
					document.addEventListener("astro:page-load", () => {
						const form = document.getElementById(
							"contact-form",
						) as HTMLFormElement;
						const success = document.getElementById("form-success");
						const resetBtn = document.getElementById("reset-form");

						form?.addEventListener("submit", (e) => {
							e.preventDefault();
							success?.classList.remove("translate-y-full");
						});

						resetBtn?.addEventListener("click", () => {
							form?.reset();
							success?.classList.add("translate-y-full");
						});
					});
				</script>
			</div>
		</section>
	</main>
</Layout>
