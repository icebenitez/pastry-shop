---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404: Page Not Found | Sweet Delights">
    <main class="min-h-screen flex flex-col">
        <div
            class="grow flex items-center justify-center px-4 py-24 text-center"
        >
            <div class="max-w-md">
                <span
                    class="text-brand-secondary text-9xl font-serif italic opacity-20 block mb-4"
                    >404</span
                >
                <h1 class="text-4xl md:text-5xl text-brand-primary mb-6 italic">
                    Oops! We burnt the cookies.
                </h1>
                <p class="text-stone-500 mb-10 leading-relaxed">
                    The page you're looking for seems to have overbaked or never
                    existed. Let's get you back to something fresh.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                        href="/"
                        class="px-8 py-3 bg-brand-primary text-white rounded-full hover:bg-stone-800 transition-colors font-medium shadow-lg shadow-brand-primary/10"
                    >
                        Return Home
                    </a>
                    <a
                        href="/menu"
                        class="px-8 py-3 border-2 border-brand-primary text-brand-primary rounded-full hover:bg-brand-primary hover:text-white transition-colors font-medium"
                    >
                        View Menu
                    </a>
                </div>
            </div>
        </div>
    </main>
</Layout>
