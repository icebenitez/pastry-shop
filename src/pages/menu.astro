---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from 'astro:content';

const allMenuItems = await getCollection('menu');

// Group by category
const groupedMenu = allMenuItems.reduce((acc: Record<string, any[]>, item: any) => {
  const { category } = item.data;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(item.data);
  return acc;
}, {} as Record<string, any[]>);

// Define category display order
const categoryOrder = ["Signature Cakes", "Morning Pastries", "Seasonal Specials"];
const menuItems = categoryOrder.map(category => ({
  category,
  items: (groupedMenu[category] || []).sort((a: any, b: any) => (a.order || 0) - (b.order || 0))
}));
---

<Layout 
  title="Our Menu | Signature Cakes & Pastries"
  description="Exquisite selection of signature cakes, morning pastries, and seasonal specials. Each creation is a masterpiece of flavor."
  navClass="bg-white border-b border-stone-100"
  isNavDark={false}
>
  <main class="bg-stone-50 min-h-screen">

    <!-- Header -->
    <header class="py-16 px-4 text-center border-b border-stone-200">
      <h1 class="text-6xl md:text-8xl text-brand-primary mb-4 italic font-light">The Menu</h1>
      <p class="text-stone-500 max-w-2xl mx-auto font-sans tracking-wide mb-8">
        Each creation is a chapter in our story of flavor, tradition, and artistry. 
        Browse our selection like a magazine of taste.
      </p>
      
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-4 max-w-2xl mx-auto">
        <button 
          class="filter-btn active px-6 py-2 rounded-full border border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-white transition-all text-xs font-bold uppercase tracking-widest"
          data-category="all"
        >
          All
        </button>
        {categoryOrder.map(cat => (
          <button 
            class="filter-btn px-6 py-2 rounded-full border border-stone-200 text-stone-500 hover:border-brand-primary hover:text-brand-primary transition-all text-xs font-bold uppercase tracking-widest"
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </header>

    <!-- Menu Sections -->
    <div class="max-w-7xl mx-auto px-4 py-20 divide-y divide-stone-200" id="menu-container">
      {menuItems.map((section) => (
        <section class="py-24 first:pt-0 menu-section" data-category={section.category}>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
            <!-- Category Title (Magazine Style Sidebar) -->
            <div class="lg:col-span-3">
              <div class="sticky top-12">
                <h2 class="text-4xl md:text-5xl text-brand-secondary mb-6 leading-tight">
                  {section.category}
                </h2>
                <div class="hidden lg:block w-full h-px bg-stone-300 mb-6"></div>
                <p class="text-stone-400 text-sm uppercase tracking-tighter hidden lg:block">
                  Pastry Shop Editorial <br /> Issue No. 01 / 2026
                </p>
              </div>
            </div>

            <!-- Items Grid -->
            <div class="lg:col-span-9">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-20">
                {section.items.map((item: any) => (
                  <div class={item.type === 'hero' ? 'md:col-span-2' : ''}>
                    {item.type === 'hero' ? (
                      /* Hero Item */
                      <div 
                        class="grid md:grid-cols-2 gap-8 items-center group cursor-pointer"
                        data-preview-img={item.image}
                      >
                        <div class="relative overflow-hidden rounded-sm aspect-4/3 shadow-2xl">
                          <Image 
                            src={item.image} 
                            alt={item.name}
                            width={800}
                            height={600}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                          />
                        </div>
                        <div class="space-y-4">
                          <div class="flex justify-between items-baseline border-b border-stone-300 pb-2">
                            <h3 class="text-3xl text-brand-primary italic">{item.name}</h3>
                            <span class="text-stone-600 font-sans">{item.price}</span>
                          </div>
                          <p class="text-stone-500 font-light leading-relaxed text-lg">
                            {item.description}
                          </p>
                          <button class="text-brand-secondary uppercase tracking-widest text-xs font-bold hover:text-brand-primary transition-all border-b border-brand-secondary pb-1">
                            Discover More
                          </button>
                        </div>
                      </div>
                    ) : (
                      /* Minimalist Item */
                      <div 
                        class="space-y-3 group hover:bg-white/50 p-4 -m-4 transition-colors rounded-lg cursor-pointer menu-item-minimal"
                        data-preview-img={item.image}
                      >
                        <div class="flex justify-between items-baseline">
                          <h3 class="text-xl text-stone-800 font-medium group-hover:text-brand-primary transition-colors">
                            {item.name}
                          </h3>
                          <span class="text-stone-500 font-sans text-sm">{item.price}</span>
                        </div>
                        {item.description && (
                          <p class="text-stone-500 text-sm font-light leading-snug">
                            {item.description}
                          </p>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Image Preview Container -->
    <div 
      id="cursor-preview" 
      class="fixed pointer-events-none z-50 overflow-hidden w-64 aspect-4/3 rounded-lg shadow-2xl opacity-0 scale-90 transition-all duration-300 ease-out border-4 border-white"
    >
      <img id="preview-img" src="" alt="" class="w-full h-full object-cover" />
    </div>

    <script>
      document.addEventListener("astro:page-load", () => {
        const preview = document.getElementById('cursor-preview');
        const previewImg = document.getElementById('preview-img') as HTMLImageElement;
        const menuItems = document.querySelectorAll('[data-preview-img]');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const sections = document.querySelectorAll('.menu-section');

        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;
        
        // Smooth following with requestAnimationFrame
        function updatePosition() {
          targetX += (mouseX - targetX) * 0.15;
          targetY += (mouseY - targetY) * 0.15;
          
          if (preview) {
            preview.style.left = `${targetX + 20}px`;
            preview.style.top = `${targetY + 20}px`;
          }
          
          requestAnimationFrame(updatePosition);
        }
        
        requestAnimationFrame(updatePosition);

        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });

        menuItems.forEach((item) => {
          item.addEventListener('mouseenter', () => {
            const imgSrc = item.getAttribute('data-preview-img');
            if (imgSrc && previewImg && preview) {
              previewImg.src = imgSrc;
              preview.style.opacity = '1';
              preview.style.transform = 'scale(1) rotate(2deg)';
            }
          });

          item.addEventListener('mouseleave', () => {
            if (preview) {
              preview.style.opacity = '0';
              preview.style.transform = 'scale(0.9) rotate(0deg)';
            }
          });
        });

        // Filter Logic
        filterBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const category = btn.getAttribute('data-category');
            
            // Update button styles
            filterBtns.forEach(b => {
               b.classList.remove('active', 'bg-brand-primary', 'text-white', 'border-brand-primary');
               b.classList.add('border-stone-200', 'text-stone-500', 'hover:text-brand-primary');
            });
            btn.classList.add('active', 'bg-brand-primary', 'text-white', 'border-brand-primary');
            btn.classList.remove('border-stone-200', 'text-stone-500', 'hover:text-brand-primary');

            // Filter sections
            sections.forEach(section => {
              const sectionCat = section.getAttribute('data-category');
              if (category === 'all' || category === sectionCat) {
                (section as HTMLElement).style.display = 'block';
                // Trigger re-entrance animation if using View Transitions or custom observers
              } else {
                (section as HTMLElement).style.display = 'none';
              }
            });
          });
        });
      });
    </script>

    <!-- Contact CTA -->
    <section class="bg-brand-primary py-24 px-4 text-center">
        <h2 class="text-white text-4xl md:text-6xl mb-8 italic font-light">Custom Commission?</h2>
        <p class="text-brand-accent/70 max-w-xl mx-auto mb-10 text-lg">
            Our pastry chefs love a challenge. Let us craft a unique centerpiece for your next celebration.
        </p>
        <a href="/#contact" class="inline-block px-12 py-4 border-2 border-white text-white hover:bg-white hover:text-brand-primary transition-all uppercase tracking-widest text-sm font-bold">
            Get in Touch
        </a>
    </section>
  </main>


</Layout>

<style>
  /* Magazine specific styles */
  h1, h2 {
    letter-spacing: -0.02em;
  }
  
  /* Custom serif for extra drama if needed */
  .italic {
    font-style: italic;
  }
</style>
