---
import StoreStatus from "./StoreStatus.astro";

const { class: className, isDark = true } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
    { href: "/", label: "Home" },
    { href: "/menu", label: "Menu" },
    { href: "/about", label: "About" },
    { href: "/#contact", label: "Contact" },
];

const textColor = isDark ? "text-white" : "text-stone-600";
const activeColor = "text-brand-secondary";
---

<nav
    class={`w-full z-50 px-6 sm:px-8 py-6 flex justify-between items-center transition-all duration-300 ${className}`}
>
    <!-- Logo & Status -->
    <div class="flex items-center gap-2 sm:gap-4 shrink-0">
        <a
            href="/"
            class="font-serif text-xl sm:text-2xl tracking-tighter text-brand-primary whitespace-nowrap"
            >Sweet Delights</a
        >
        <div class="hidden xs:block">
            <StoreStatus />
        </div>
    </div>

    <!-- Desktop Nav Links -->
    <div
        class={`hidden md:flex space-x-8 uppercase tracking-widest text-[10px] font-bold ${textColor}`}
    >
        {
            navItems.map((item) => {
                const isActive =
                    currentPath === item.href ||
                    (item.href !== "/" && currentPath.startsWith(item.href));
                return (
                    <a
                        href={item.href}
                        class={`transition-colors hover:text-brand-primary relative group ${isActive ? activeColor : ""}`}
                    >
                        {item.label}
                        <span
                            class={`absolute -bottom-1 left-0 w-0 h-[1.5px] bg-brand-primary transition-all duration-300 group-hover:w-full ${isActive ? "w-full" : ""}`}
                        />
                    </a>
                );
            })
        }
    </div>

    <!-- Mobile Menu Button -->
    <button
        id="mobile-menu-btn"
        class={`md:hidden p-2 rounded-lg transition-colors focus:outline-none z-60 ${isDark ? "text-white" : "text-brand-primary"}`}
        aria-label="Toggle Menu"
    >
        <div
            class="w-6 h-5 flex flex-col justify-between relative overflow-hidden"
        >
            <span
                class="block w-full h-[2px] bg-current transform transition-all duration-300 origin-left"
                id="bar-1"></span>
            <span
                class="block w-full h-[2px] bg-current transform transition-all duration-300"
                id="bar-2"></span>
            <span
                class="block w-full h-[2px] bg-current transform transition-all duration-300 origin-left"
                id="bar-3"></span>
        </div>
    </button>
</nav>

<!-- Mobile Menu Overlay -->
<div
    id="mobile-overlay"
    class="fixed inset-0 bg-stone-50 z-55 translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col justify-center items-center p-8 overflow-hidden"
>
    <!-- Background Decor (Optional but adds premium feel) -->
    <div
        class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-brand-accent/20 rounded-full blur-3xl -z-10 animate-pulse"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-brand-secondary/10 rounded-full blur-3xl -z-10 animate-pulse delay-1000"
    >
    </div>

    <div class="flex flex-col items-center space-y-10 text-center">
        <div
            class="font-serif text-3xl tracking-tighter text-brand-primary mb-4"
        >
            Sweet Delights
        </div>

        <div class="flex flex-col space-y-6">
            {
                navItems.map((item, index) => {
                    const isActive =
                        currentPath === item.href ||
                        (item.href !== "/" &&
                            currentPath.startsWith(item.href));
                    return (
                        <a
                            href={item.href}
                            class={`text-2xl uppercase tracking-[0.2em] font-light transition-all duration-500 transform translate-y-10 opacity-0 nav-mobile-link ${isActive ? "text-brand-secondary font-medium" : "text-stone-400 group-hover:text-brand-primary"}`}
                            style={`transition-delay: ${index * 100}ms`}
                        >
                            {item.label}
                        </a>
                    );
                })
            }
        </div>

        <div
            class="mt-8 transform translate-y-10 opacity-0 nav-mobile-footer transition-all duration-500 delay-300"
        >
            <StoreStatus />
        </div>
    </div>
</div>

<script>
    function setupNav() {
        const btn = document.getElementById("mobile-menu-btn");
        const overlay = document.getElementById("mobile-overlay");
        const bars = [
            document.getElementById("bar-1"),
            document.getElementById("bar-2"),
            document.getElementById("bar-3"),
        ];
        const links = document.querySelectorAll(".nav-mobile-link");
        const footer = document.querySelector(".nav-mobile-footer");

        let isOpen = false;

        function toggleMenu() {
            if (!overlay || !bars[0] || !bars[1] || !bars[2] || !footer) return;

            isOpen = !isOpen;

            if (isOpen) {
                // Open states
                overlay.classList.remove("translate-x-full");
                document.body.style.overflow = "hidden";

                // Burger animation
                bars[0].classList.add("rotate-[35deg]", "scale-x-[1.2]");
                bars[1].classList.add("opacity-0", "-translate-x-4");
                bars[2].classList.add("-rotate-[35deg]", "scale-x-[1.2]");

                // Content animation
                links.forEach((link) => {
                    link.classList.remove("translate-y-10", "opacity-0");
                });
                footer.classList.remove("translate-y-10", "opacity-0");
            } else {
                // Close states
                overlay.classList.add("translate-x-full");
                document.body.style.overflow = "";

                // Burger animation reset
                bars[0].classList.remove("rotate-[35deg]", "scale-x-[1.2]");
                bars[1].classList.remove("opacity-0", "-translate-x-4");
                bars[2].classList.remove("-rotate-[35deg]", "scale-x-[1.2]");

                // Content animation reset
                links.forEach((link) => {
                    link.classList.add("translate-y-10", "opacity-0");
                });
                footer.classList.add("translate-y-10", "opacity-0");
            }
        }

        btn?.addEventListener("click", toggleMenu);

        // Close menu on link click
        links.forEach((link) => {
            link.addEventListener("click", () => {
                if (isOpen) toggleMenu();
            });
        });
    }

    // Run on initial load & after view transitions
    setupNav();
    document.addEventListener("astro:after-swap", setupNav);
</script>

<style>
    /* Hide scrollbar when menu is open maybe? 
       Actually let's just use overflow-hidden on body via JS */
</style>
